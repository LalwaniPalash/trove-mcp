# Optional contact email for polite OpenAlex usage.
TROVE_CONTACT_EMAIL=

# Optional Semantic Scholar key to raise rate limits.
SEMANTIC_SCHOLAR_API_KEY=
SEMANTIC_SCHOLAR_BASE_URL=

# Optional Unpaywall email parameter.
UNPAYWALL_EMAIL=
UNPAYWALL_BASE_URL=

# Optional CORE key (without key, some endpoints may be limited).
CORE_API_KEY=
CORE_BASE_URL=

# Optional provider endpoint overrides.
OPENALEX_BASE_URL=
ARXIV_BASE_URL=
PUBMED_BASE_URL=
HUGGINGFACE_BASE_URL=

# Optional bearer token required only in HTTP mode.
TROVE_HTTP_BEARER_TOKEN=

# SQLite file path.
TROVE_DB_PATH=~/.trove-mcp/trove.db

# Enable verbose stderr debug logs.
TROVE_DEBUG=false

# Optional comma-separated tool disable list for strict release gating.
# Example: TROVE_DISABLED_TOOLS=get_trending_papers,find_similar_papers
TROVE_DISABLED_TOOLS=

# HTTP server configuration for streamable mode.
TROVE_HTTP_PORT=3000
TROVE_HTTP_HOST=127.0.0.1
